      <CompiledRunModel Key="11" SourceCode="///Stijghoogteverloop model 4A;&#xD;&#xA;L1 = L_geometrisch - L_BUT;&#xD;&#xA;Φ_uittrede = r * (WS-WS_mean)+Φ_mean;&#xD;&#xA;&#xD;&#xA;///UPLIFT;&#xD;&#xA;ΔΦc = d_deklaag * ((y_satdek - y_water) / y_water);&#xD;&#xA;h_uittrede = Math.Max(maaiveld , Φ_polder);&#xD;&#xA;ΔΦ = Φ_uittrede - h_uittrede;&#xD;&#xA;Zu = mu * ΔΦc - ΔΦ;&#xD;&#xA;&#xD;&#xA;///HEAVE;&#xD;&#xA;i = (Φ_uittrede - h_uittrede) / d_deklaag;&#xD;&#xA;Zh = ic - i;&#xD;&#xA;&#xD;&#xA;///PIPING;&#xD;&#xA;L_effvoorland = λ1 * Math.Tanh(L1 / λ1);&#xD;&#xA;L = m_kwl * (L_effvoorland + L_BUT);&#xD;&#xA;&#xD;&#xA;///Sellmeijer;&#xD;&#xA;Fr = ((26.0 - y_water) / y_water) * 0.25 * Math.Tan(37 * Math.PI / 180);&#xD;&#xA;Fs = 2.08E-4  * Math.Pow((d70/1.0E6) / 2.08E-4 , 0.4) / Math.Pow(L * (k / (3600 * 24)) * 1.33 / (9.81 * 1E6)  , 1.0 / 3.0);&#xD;&#xA;Fg =  0.91 * Math.Pow(D / L , 0.04 + (0.28 / (Math.Pow(D / L , 2.8) - 1)));&#xD;&#xA;Hc = Fr * Fs * Fg * L;&#xD;&#xA;Zp = mp * Hc - (WS - h_uittrede - 0.3 * d_deklaag);&#xD;&#xA;&#xD;&#xA;" Language="CSharp" Version="3.7" Invocations="345" AddMoreVariables="False">
